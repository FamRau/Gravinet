{
  "name": "Gravinet",
  "version": "2.3.6",
  "description": "Gravinet – Stakeholder-Management",
  "main": "main.js",
  "author": "Direktion 4 Logistik",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux AppImage",
    "build-win": "electron-builder --win nsis",
    "build-mac": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "at.gravinet.app",
    "productName": "Gravinet",
    "copyright": "Direktion 4 Logistik",
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Office",
      "icon": "app/icons",
      "desktop": {
        "Name": "Gravinet",
        "Comment": "Gravinet – Stakeholder-Management",
        "Categories": "Office;ProjectManagement;",
        "StartupWMClass": "gravinet"
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "app/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "app/icons/icon.icns",
      "category": "public.app-category.productivity"
    },
    "files": [
      "main.js",
      "preload.js",
      "app/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
